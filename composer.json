{
    "name": "wirecharts/wirecharts",
    "description": "Flux-style chart components for Laravel Livewire 4. 30+ chart types in one elegant package.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://wirecharts.io",
    "authors": [
        {
            "name": "kwhorne",
            "homepage": "https://github.com/kwhorne"
        }
    ],
    "support": {
        "issues": "https://github.com/kwhorne/wirecharts/issues",
        "source": "https://github.com/kwhorne/wirecharts",
        "docs": "https://wirecharts.io/docs"
    },
    "keywords": ["laravel", "livewire", "flux", "charts", "blade"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "WireCharts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WireCharts\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WireCharts\\WireChartsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
